/* Agent Skills Manager — macOS-flavoured theme template.

   This file is NOT loaded directly: theme.py substitutes the @@TOKEN@@
   placeholders below with a light or dark palette (chosen from the system
   colour scheme) before applying it. Edit colours in theme.py, structure here.

   Design language: macOS Ventura/Sonoma "System Settings" — system blue accent,
   soft separators, generous radii, a sidebar with an inset pill selection, and
   filled push buttons rather than hairline-outlined ones. */

QWidget {
    background: @@BG@@;
    color: @@TEXT@@;
    font-size: 13px;
}

/* Labels and toggles are transparent so they don't paint the window colour as
   opaque rectangles when they sit inside white cards. */
QLabel, QCheckBox, QRadioButton {
    background: transparent;
}

/* Title bar across the top of the window */
QFrame#titleBar {
    background: @@TITLEBAR_BG@@;
    border-bottom: 1px solid @@SEPARATOR@@;
}
QLabel#appTitle {
    font-size: 13px;
    font-weight: 600;
    color: @@TEXT@@;
}

/* Left navigation — translucent macOS sidebar with an inset pill selection */
QListWidget#nav {
    background: @@SIDEBAR_BG@@;
    border: none;
    border-right: 1px solid @@SEPARATOR@@;
    outline: 0;
    padding: 10px 8px;
}
QListWidget#nav::item {
    height: 30px;
    padding-left: 10px;
    margin: 1px 0;
    border-radius: 7px;
    color: @@TEXT@@;
}
QListWidget#nav::item:selected {
    background: @@ACCENT@@;
    color: @@ON_ACCENT@@;
    font-weight: 600;
}
QListWidget#nav::item:hover:!selected {
    background: @@NAV_HOVER@@;
}

/* Page header / titles */
QLabel#pageTitle {
    font-size: 22px;
    font-weight: 700;
}
QLabel#pageSubtitle, QLabel[muted="true"] {
    color: @@MUTED@@;
}
QLabel#cardTitle {
    color: @@MUTED@@;
    font-size: 11px;
    font-weight: 600;
}
QLabel#cardValue {
    font-size: 21px;
    font-weight: 600;
}

/* Cards — borderless panels; depth comes from a drop shadow (base.py) */
QFrame[card="true"] {
    background: @@CARD_BG@@;
    border: 1px solid @@CARD_BORDER@@;
    border-radius: 12px;
}

/* Buttons — filled, rounded, macOS push-button feel */
QPushButton {
    background: @@BTN_BG@@;
    border: 1px solid @@BTN_BORDER@@;
    border-radius: 7px;
    min-height: 30px;
    padding: 0 16px;
    font-weight: 500;
}
QPushButton:hover {
    background: @@BTN_HOVER@@;
}
QPushButton:pressed {
    background: @@BTN_PRESSED@@;
}
QPushButton:disabled {
    color: @@MUTED@@;
    background: @@BTN_BG@@;
    border-color: @@CARD_BORDER@@;
}
QPushButton#primary {
    background: @@ACCENT@@;
    border-color: @@ACCENT@@;
    color: @@ON_ACCENT@@;
    font-weight: 600;
}
QPushButton#primary:hover {
    background: @@ACCENT_HOVER@@;
    border-color: @@ACCENT_HOVER@@;
}
QPushButton#primary:pressed {
    background: @@ACCENT_PRESSED@@;
    border-color: @@ACCENT_PRESSED@@;
}
QPushButton#primary:disabled {
    background: @@ACCENT_DISABLED@@;
    border-color: @@ACCENT_DISABLED@@;
    color: @@ON_ACCENT@@;
}
QPushButton#danger {
    background: @@CARD_BG@@;
    border: 1px solid @@DANGER@@;
    color: @@DANGER@@;
    font-weight: 600;
}
QPushButton#danger:hover {
    background: @@DANGER@@;
    color: #ffffff;
}
QPushButton#danger:disabled {
    border-color: @@DANGER_DISABLED@@;
    color: @@DANGER_DISABLED@@;
    background: @@CARD_BG@@;
}

/* Inputs */
QLineEdit, QComboBox, QPlainTextEdit, QTextEdit {
    background: @@INPUT_BG@@;
    border: 1px solid @@INPUT_BORDER@@;
    border-radius: 6px;
    min-height: 30px;
    padding: 0 10px;
    selection-background-color: @@SELECTION_BG@@;
    selection-color: @@TEXT@@;
}
QPlainTextEdit, QTextEdit {
    padding: 8px 10px;
}
QLineEdit:focus, QComboBox:focus, QPlainTextEdit:focus, QTextEdit:focus {
    border-color: @@ACCENT@@;
}
QComboBox::drop-down {
    border: none;
    width: 22px;
}

/* Tables */
QTableView {
    background: @@CARD_BG@@;
    border: 1px solid @@CARD_BORDER@@;
    border-radius: 10px;
    gridline-color: @@SEPARATOR@@;
    selection-background-color: @@SELECTION_BG@@;
    selection-color: @@TEXT@@;
}
QTableView::item {
    padding: 5px 8px;
}
QHeaderView::section {
    background: @@TABLE_HEADER_BG@@;
    color: @@MUTED@@;
    border: none;
    border-bottom: 1px solid @@SEPARATOR@@;
    padding: 7px 8px;
    font-weight: 600;
}

/* Lists (diff/changes) */
QListWidget {
    background: @@CARD_BG@@;
    border: 1px solid @@CARD_BORDER@@;
    border-radius: 10px;
    outline: 0;
}
QListWidget::item {
    min-height: 26px;
    padding: 3px 8px;
    border-radius: 5px;
}
QListWidget::item:selected {
    background: @@SELECTION_BG@@;
    color: @@TEXT@@;
}

/* Status badges (badge + level set via dynamic properties) */
QLabel[badge="true"] {
    border-radius: 9px;
    padding: 2px 10px;
    font-weight: 600;
    font-size: 11px;
}
QLabel[badge="true"][level="ok"]    { background: @@OK_BG@@;    color: @@OK_FG@@; }
QLabel[badge="true"][level="warn"]  { background: @@WARN_BG@@;  color: @@WARN_FG@@; }
QLabel[badge="true"][level="error"] { background: @@ERROR_BG@@; color: @@ERROR_FG@@; }
QLabel[badge="true"][level="muted"] { background: @@MUTED_BG@@; color: @@MUTED@@; }

/* Red emphasis for destructive counts */
QLabel#dangerCount {
    color: @@DANGER@@;
    font-weight: 600;
}

/* Checkboxes */
QCheckBox { spacing: 8px; }
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid @@INPUT_BORDER@@;
    border-radius: 5px;
    background: @@INPUT_BG@@;
}
QCheckBox::indicator:checked {
    background: @@ACCENT@@;
    border-color: @@ACCENT@@;
    image: url(@@CHECK_ICON@@);
}

/* Monospace log pane */
QPlainTextEdit#logView {
    background: @@LOG_BG@@;
    color: @@LOG_TEXT@@;
    font-family: "SF Mono", "Menlo", "JetBrains Mono", "Consolas", "DejaVu Sans Mono", monospace;
    border: 1px solid @@CARD_BORDER@@;
    border-radius: 10px;
}

/* Scrollbars — thin, overlay-style */
QScrollBar:vertical {
    background: transparent;
    width: 12px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: @@SCROLLBAR@@;
    border-radius: 5px;
    min-height: 30px;
    margin: 2px;
}
QScrollBar::handle:vertical:hover { background: @@SCROLLBAR_HOVER@@; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: transparent; }
QScrollBar:horizontal {
    background: transparent;
    height: 12px;
    margin: 0;
}
QScrollBar::handle:horizontal {
    background: @@SCROLLBAR@@;
    border-radius: 5px;
    min-width: 30px;
    margin: 2px;
}
QScrollBar::handle:horizontal:hover { background: @@SCROLLBAR_HOVER@@; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal { background: transparent; }

QStatusBar {
    background: @@TITLEBAR_BG@@;
    border-top: 1px solid @@SEPARATOR@@;
    color: @@MUTED@@;
}
QStatusBar::item { border: none; }
